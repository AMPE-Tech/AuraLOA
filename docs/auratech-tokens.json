  "typography": {
    "font-sans":  { "$value": "\"DM Sans\", Inter, sans-serif", "$type": "fontFamily", "$description": "Fonte principal — UI" },
    "font-serif": { "$value": "Georgia, serif",                 "$type": "fontFamily" },
    "font-mono":  { "$value": "JetBrains Mono, monospace",      "$type": "fontFamily" },
    "base-size":  { "$value": "14px",                           "$type": "dimension",  "$description": "html font-size global" }
  },

  "border-radius": {
    "sm":  { "$value": "0.1875rem", "$type": "dimension", "$description": "3px" },
    "md":  { "$value": "0.375rem",  "$type": "dimension", "$description": "6px" },
    "lg":  { "$value": "0.5625rem", "$type": "dimension", "$description": "9px — tailwind lg" },
    "base":{ "$value": "0.5rem",    "$type": "dimension", "$description": "8px — CSS --radius" },
    "full":{ "$value": "9999px",    "$type": "dimension", "$description": "pills / badges / topbar buttons" }
  },

  "spacing": {
    "base": { "$value": "0.25rem", "$type": "dimension", "$description": "--spacing = 4px" },
    "topbar-px":    { "$value": "1.75rem", "$type": "dimension", "$description": "px-7 — padding horizontal topbar" },
    "topbar-py":    { "$value": "1rem",    "$type": "dimension", "$description": "py-4 — padding vertical topbar" },
    "topbar-height":{ "$value": "auto",    "$type": "dimension", "$description": "sticky, sem altura fixa — py-4 + conteúdo" },
    "max-width":    { "$value": "1400px",  "$type": "dimension", "$description": "max-w-[1400px] — container" },
    "card-padding": { "$value": "1.25rem", "$type": "dimension", "$description": "p-5 — KPI cards" }
  },

  "elevation": {
    "shadow-sm": { "$value": "0 1px 2px 0 rgba(0,0,0,.05)", "$type": "shadow", "$description": "KPI card default" },
    "shadow-md": { "$value": "0 4px 6px -1px rgba(0,0,0,.07), 0 2px 4px -2px rgba(0,0,0,.05)", "$type": "shadow", "$description": "KPI card hover" },
    "elevate-1-light": { "$value": "rgba(0,0,0,.03)",   "$type": "color", "$description": "--elevate-1 light" },
    "elevate-2-light": { "$value": "rgba(0,0,0,.08)",   "$type": "color", "$description": "--elevate-2 light" },
    "elevate-1-dark":  { "$value": "rgba(255,255,255,.03)", "$type": "color" },
    "elevate-2-dark":  { "$value": "rgba(255,255,255,.07)", "$type": "color" }

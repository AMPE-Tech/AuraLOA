  "logo": {
    "icon":       { "$value": "Scale (lucide-react)", "$type": "other" },
    "icon-size":  { "$value": "w-10 h-10 (40px)", "$type": "dimension" },
    "icon-inner": { "$value": "w-5 h-5 (20px)", "$type": "dimension" },
    "gradient":   { "$value": "linear-gradient(135deg, #06b6d4, #7c3aed)", "$type": "other" },
    "brand-name": { "$value": "AuraLOA", "$type": "other" },
    "tagline-pt": { "$value": "Análise Inteligente de Precatórios", "$type": "other" }
  },

  "dependencies": {
    "tailwindcss": "^3.4.17",
    "recharts":    "^2.15.2",
    "lucide-react":"^0.453.0",
    "radix-ui":    "todas as primitivas ^1.x / ^2.x",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "@tailwindcss/typography": "^0.5.15"
  }
}

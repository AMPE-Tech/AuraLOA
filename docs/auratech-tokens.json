{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "project": "AuraTECH / AuraLOA",
    "extracted": "2026-03-30",
    "sources": ["client/src/index.css", "tailwind.config.ts", "client/src/components/public-topbar.tsx"]
  },

  "color": {
